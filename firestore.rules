rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (required)
    //   - photoURL: string
    //   - email: string
    //   - lastSeen: timestamp
    //
    // Collection: chats
    // Document ID: {chatId}
    // Fields:
    //   - participants: list (required) - UIDs of the two participants
    //   - createdAt: timestamp
    //   - lastMessage: string (encrypted)
    //   - lastMessageTimestamp: timestamp
    //
    // Collection: chats/{chatId}/messages
    // Document ID: {messageId}
    // Fields:
    //   - chatId: string
    //   - senderId: string
    //   - encryptedText: string (AES encrypted)
    //   - timestamp: timestamp
    //   - type: string
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "dnsnksks618@gmail.com" && request.auth.token.email_verified == true));
    }

    function isChatParticipant(chatId) {
      return isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100;
    }

    function isValidChat(data) {
      return data.keys().hasAll(['participants', 'createdAt']) &&
             data.participants is list && data.participants.size() == 2 &&
             isAuthenticated() && request.auth.uid in data.participants;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['chatId', 'senderId', 'encryptedText', 'timestamp']) &&
             data.chatId is string &&
             data.senderId == request.auth.uid &&
             data.encryptedText is string && data.encryptedText.size() < 5000;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if true;
      allow create, update: if true; // Temporary allow for profile-based login without Firebase Auth
    }

    match /chats/{chatId} {
      allow read, create, update: if true; // Temporary allow for profile-based login
      
      match /messages/{messageId} {
        allow read, create: if true; // Temporary allow for profile-based login
      }
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
